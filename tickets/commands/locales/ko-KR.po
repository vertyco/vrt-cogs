msgstr "티켓 패널 버튼 색상을 설정합니다.\n"

#: tickets\commands\admin.py:61
msgid "Valid colors are "
msgstr "유효한 색상은 다음과 같습니다 "

#: tickets\commands\admin.py:62
msgid "<panel_name> <button_color>`"
msgstr "<패널_이름> <버튼_색상>"

#: tickets\commands\admin.py:63
msgid "Button Color"
msgstr "버튼 색상"

#: tickets\commands\admin.py:64
