#: tickets\common\utils.py:135
#, docstring
msgid "Proxy wrapper for discord.Message that allows setting the 'interaction' property.\n\n"
"    The chat-exporter library tries to set message.interaction = \"\" which fails in newer\n"
"    discord.py versions where 'interaction' is a read-only property. This proxy intercepts\n"
"    that assignment while delegating all other attribute access to the wrapped message.\n"
"    "
msgstr ""

#: tickets\common\utils.py:170
#, docstring
msgid "Wrap messages in proxy objects that allow chat-exporter to set 'interaction'.\n\n"
"    Args:\n"
"        messages: List of discord.Message objects\n\n"
"    Returns:\n"
"        List of _MessageProxy objects wrapping the original messages\n"
"    "
msgstr ""

