#: guildlog\guildlog.py:188
#, docstring
msgid "Configure join settings"
msgstr ""

#: guildlog\guildlog.py:193
#, docstring
msgid "\n"
"        Set the guild join message\n\n"
"        Valid placeholders are:\n"
"        `{guild}` - the name of the guild the bot just joined\n"
"        `{guildid}` - the id of the guild the bot just joined\n"
"        `{servers}` - the amount of servers the bot is now in\n"
"        `{botname}` - the name of the bot\n"
"        `{bots}` - the amount of bots in the guild\n"
"        `{members}` - the member count of the guild\n\n"
"        To set back to default just to `default` as the message value\n"
"        "
msgstr ""

#: guildlog\guildlog.py:212
#, docstring
msgid "\n"
"        Set the color of the guild join embed\n\n"
"        If embeds are on, this will be the join color.\n"
"        Color value must be an integer\n"
"        "
msgstr ""

#: guildlog\guildlog.py:228
#, docstring
msgid "Configure leave settings"
msgstr ""

#: guildlog\guildlog.py:233
#, docstring
msgid "\n"
"        Set the guild leave message\n\n"
"        Valid placeholders are:\n"
"        `{guild}` - the name of the guild the bot just joined\n"
"        `{guildid}` - the id of the guild the bot just joined\n"
"        `{servers}` - the amount of servers the bot is now in\n"
"        `{botname}` - the name of the bot\n"
"        `{bots}` - the amount of bots that were in the guild\n"
"        `{members}` - the member count of the guild\n\n"
"        To set back to default just to `default` as the message value\n"
"        "
msgstr ""

#: guildlog\guildlog.py:252
#, docstring
msgid "\n"
"        Set the color of the guild leave embed\n\n"
"        If embeds are on, this will be the leave color.\n"
"        Color value must be an integer\n"
"        "
msgstr ""

