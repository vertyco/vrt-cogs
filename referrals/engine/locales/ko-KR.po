"    Args:\n"
"        cog_instance (commands.Cog | Path): The instance of the cog to create migrations for.\n"
"        name (str): The name of the migration to create.\n\n"
"    Returns:\n"
"        str: The result of the migration process, including any output messages.\n"
"    "
msgstr ""

