#: pixl\pixl.py:41
#, docstring
msgid "\n"
"    Guess pictures for points\n\n"
"    Pixl is an image guessing game that reveals parts of an image over time while users race to guess the correct answer first.\n\n"
"    **Images are split up into 192 blocks and slowly revealed over time.**\n"
"    The score of the game is based on how many blocks are left when the image is guessed.\n"
"    "
msgstr ""

