#: events\events.py:480
#, docstring
msgid "\n"
"        (Toggle) Auto delete events from config when they complete\n\n"
"        If auto delete is enabled, the messages in the event channel will need to be cleaned up manually\n"
"        "
msgstr ""

#: events\events.py:495
#, docstring
msgid "\n"
"        (Toggle) Include event results in the messages to delete on cleanup\n\n"
"        If this is on when an event is deleted and the user chooses to clean up the messages,\n"
"        the results announcement will also be deleted\n"
"        "
msgstr ""

#: events\events.py:511
#, docstring
msgid "\n"
"        Add/Remove staff roles\n\n"
"        If ping staff is enabled, these roles will be pinged on event completion\n"
"        "
msgstr ""

#: events\events.py:528
#, docstring
msgid "\n"
"        Add/Remove notify roles\n\n"
"        These roles will be pinged on event start and completion\n"
"        "
msgstr ""

#: events\events.py:545
#, docstring
msgid "\n"
"        Add/Remove blacklisted roles\n\n"
"        These roles are not allowed to enter events, but can still vote on them\n"
"        "
msgstr ""

#: events\events.py:562
#, docstring
msgid "\n"
"        Add/Remove blacklisted users\n\n"
"        These users are not allowed to enter events, but can still vote on them\n"
"        "
msgstr ""

#: events\events.py:579
#, docstring
msgid "\n"
"        Set the default emoji for votes\n\n"
"        Changing the vote emoji only affects events created after this is changed.\n"
"        Existing events will still use the previous emoji for votes\n"
"        "
msgstr ""

#: events\events.py:599
#, docstring
msgid "\n"
"        End an event early, counting votes/announcing the winner\n\n"
