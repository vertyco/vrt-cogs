msgstr "La penalización de frecuencia se ha establecido en **{}**"

#: assistant\commands\admin.py:1632
#, docstring
msgid "\n"
"        Set the presence penalty for the model (-2.0 to 2.0)\n"
"        - Defaults is 0\n\n"
"        Positive values penalize new tokens based on whether they appear in the text so far, increasing the model's likelihood to talk about new topics.\n"
"        "
msgstr "\n"
"        Establezca la penalización de presencia para el modelo (-2.0 a 2.0)\n"
"        - El valor predeterminado es 0\n\n"
"        Los valores positivos penalizan los nuevos tokens según si aparecen en el texto hasta ahora, aumentando la probabilidad de que el modelo hable sobre nuevos temas.\n"
"        "

#: assistant\commands\admin.py:1639
msgid "Presence penalty must be between **-2.0** and **2.0**"
msgstr "La penalización de presencia debe estar entre **-2.0** y **2.0**"

#: assistant\commands\admin.py:1644
