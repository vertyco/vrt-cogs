#: upgradechat\upgradechat.py:21
#, docstring
msgid "\n"
"    Upgrade.Chat API integration for buying economy credits directly instead of roles\n\n"
"    https://upgrade.chat/\n"
"    "
msgstr ""

#: upgradechat\upgradechat.py:35
#, docstring
msgid "No data to delete"
msgstr ""

#: upgradechat\upgradechat.py:60
#, docstring
msgid "Base command for cog settings"
msgstr ""

#: upgradechat\upgradechat.py:64
#, docstring
msgid "\n"
"        Set your Upgrade.Chat api tokens\n"
"        By using this feature it is assumed that you are already familiar with Upgrade.Chat\n\n"
"        1. Create your api keys here: https://upgrade.chat/developers\n\n"
"        2. Copy your client ID and Client Secret\n\n"
"        3. Run this command with your credentials\n\n"
"        **Enjoy!**\n"
"        "
msgstr ""

#: upgradechat\upgradechat.py:89
#, docstring
msgid "\n"
"        Set the worth of 1 unit of real currency to economy credits\n\n"
"        for example, if `credit_worth` is 100, then $1 = 100 Credits\n"
"        "
msgstr ""

#: upgradechat\upgradechat.py:100
#, docstring
msgid "\n"
"        Set the message the bot sends when a user claims a purchase\n\n"
"        Valid placeholders:\n"
"        {mention} - mention the user\n"
"        {username} - the users discord name\n"
"        {displayname} - the users nickname(if they have one)\n"
"        {uid} - the users Discord ID\n"
"        {guild} - guild name\n"
"        {creditsname} - name of the currency in your guild\n"
"        {amount} - the amount of credits the user has claimed\n\n"
"        set to `default` to use the default message\n"
"        "
msgstr ""

#: upgradechat\upgradechat.py:119
#, docstring
msgid "\n"
"        Add an Upgrade.Chat product by UUID\n\n"
"        This can be any type of product, either subscription or one-time purchase.\n"
"        Users will be accredited based on `amount spend * conversion ratio`.\n"
"        Transactions can only be claimed once.\n"
"        "
msgstr ""

